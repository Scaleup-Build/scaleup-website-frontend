# Example environment variables for this project
# Copy this file to ".env" and fill in real values for your environment.

# Base URL for API requests used by the frontend (must include scheme)
VITE_API_BASE_URL=https://api.example.com # replace with your API base URL (do not commit secrets)

# Example: add other VITE_ prefixed variables here, e.g.
# VITE_PAYMENTS_KEY=your_key_here
# VITE_ANALYTICS_ID=G-XXXXXXX

# IMPORTANT: Do NOT commit a real .env with secrets. Keep .env in .gitignore.
